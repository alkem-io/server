NODE_ENV=dev
AUTH_ADMIN_PASSWORD=changeme
SUBSCRIPTIONS_ENABLED=true
NOTIFICATIONS_ENABLED=true
LOGGING_LEVEL_CONSOLE=verbose
LOGGING_FORMAT_JSON=false
ENABLE_ORM_LOGGING=false

#ELASTICSEARCH_URL=https://sandbox-elastic.example/
ELASTICSEARCH_API_KEY=
ELASTIC_SEARCH_INDEX_PATTERN=alkemio-data-acc-
ELASTIC_INDEX_ACTIVITY_NAME=
ELASTIC_INDEX_GUIDANCE_USAGE_NAME=

PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_THROTTLE_MAX_PER_MINUTE=99

# OIDC BFF (003-alkemio-oidc-idp).
# The HMAC keys below are placeholder strings — usable as-is for local-dev
# (`cp .env.example .env && pnpm start` against the local docker-compose stack)
# but you should replace them before sharing a build with anyone else. Mint via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# k8s overlays inject real secrets via the Alkemio-secrets operator — these
# placeholder values MUST never appear in any committed manifest beyond this file.
HYDRA_ISSUER_URL=http://localhost:3000/
HYDRA_JWKS_URL=http://localhost:3000/.well-known/jwks.json
ALKEMIO_WEB_CLIENT_ID=alkemio-web
BEARER_AUD_ALLOW_LIST=alkemio-web,synapse-client,element-client,ecosystem-analytics
OIDC_REFRESH_LEEWAY_S=30
STATE_HMAC_KEY=placeholder-state-hmac-key-change-me
PRE_AUTH_COOKIE_SIGNING_KEY=placeholder-pre-auth-cookie-signing-key-change-me
SESSION_SIGNING_KEY=placeholder-session-signing-key-change-me
