{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      "**/*.yaml",
      "**/*.yml",
      {
        "include": "domain/collaboration/collabora-document/templates/*.docx",
        "outDir": "dist/src"
      },
      {
        "include": "domain/collaboration/collabora-document/templates/*.xlsx",
        "outDir": "dist/src"
      },
      {
        "include": "domain/collaboration/collabora-document/templates/*.pptx",
        "outDir": "dist/src"
      }
    ]
  }
}
